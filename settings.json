{
  "providers": {
    "flm": {
      "base_url": "http://127.0.0.1:52625",
      "api_key": "${FLM_API_KEY}",        // use env var, do NOT commit secrets
      "default_model": "Qwen3-4B-Instruct-2507-NPU2",
      "fallback_model": "llama3.2:1b",
      "timeout": 120,                     // higher for local model startup
      "max_retries": 5,                   // bounded retries
      "max_tokens": 32000,
      "stream": true,
      "health_path": "/v1/health",        // health endpoint to probe
      "chat_path": "/v1/chat/completions",     // common FLM chat/completions path
      "models_path": "/v1/models",
      "request_headers": {
        "Accept": "application/json"
      }
    },
//    "openai": {
//      "api_key": "${OPENAI_API_KEY}",
//      "default_model": "gpt-4o",
//      "timeout": 60,
//      "max_retries": 3
//    },
    "anthropic": {
      "api_key": "${ANTHROPIC_API_KEY}",
      "default_model": "claude-sonnet-4",
      "timeout": 90,
      "max_retries": 3
    },
    "gemini": {
      "api_key": "${GEMINI_API_KEY}",
      "default_model": "gemini-2.5-pro",
      "fallback_model": "gemini-2.5-flash",
      "timeout": 120,
      "max_retries": 3
    },
    "ollama": {
      "base_url": "http://localhost:11434",
      "default_model": "qwen2.5-coder:32b",
      "timeout": 180
    },
  },
  {
    "models": [ 
      { 
        "id": "ollama/llama3",
        "provider": "openai", 
        "apiBase": "http://localhost:11434/v1", 
        "apiKey": "not-needed" 
      } 
    ]
  },
  {
    "agents": {
      "planner": {
        "provider": "gemini",
        "model": "gemini-2.5-pro",
        "temperature": 0.3,
        "max_tokens": 8000
      },
      "coder": {
        "provider": "anthropic",
        "model": "claude-sonnet-4",
        "temperature": 0.0,
        "max_tokens": 16000
      },
      "reviewer": {
        "provider": "gemini",
        "model": "gemini-2.5-flash",
        "temperature": 0.2,
        "max_tokens": 4000
      },
      "tester": {
        "provider": "openai",
        "model": "gpt-4o-mini",
        "temperature": 0.1,
        "max_tokens": 8000
      }
    },
  },
  "swarm": {
    "max_concurrent_tasks": 4,
    "recursion_depth_limit": 5,
    "enable_cascade_context": true,
    "enable_state_transactions": true
  },
  "filesystem": {
    "watch_patterns": ["*.py", "*.md", "*.toml"],
    "ignore_patterns": ["__pycache__", ".git", ".pytest_cache", "*.pyc"],
    "backup_enabled": true,
    "backup_dir": ".pyagent_backups"
  },
  "logging": {
    "level": "INFO",
    "file": "logs/pyagent.log",
    "max_bytes": 10485760,
    "backup_count": 5,
    "redact_secrets": true
  },
  "testing": {
    "auto_run_tests": true,
    "test_command": "pytest tests/ -q",
    "coverage_threshold": 80
  },
  "mcp": {
    "enabled": true,
    "discovery_timeout": 10,
    "tool_cache_ttl": 3600
  },
  "rust_core": {
    "enabled": true,
    "metrics_threshold": 1000,
    "bulk_operations_threshold": 50
  }
}