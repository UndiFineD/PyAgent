      "component_id": "SEMANTIC_001",
      "name": "Embedding Generation Service",
      "type": "Service",
      "description": "Generate and manage embeddings for all ideas and documents",
      "implementation": {
        "api": "OpenAI text-embedding-3-large",
        "model": "text-embedding-3-large",
        "dimensions": 3072,
        "batch_size": 128,
        "cache_backend": "Redis"
      },
      "features": [
        "Batch embedding generation",
        "Incremental updates",
        "Fallback to local models (sentence-transformers)",
        "Embedding quality metrics",
        "Cache management"
      ],
      "estimated_effort": 23,
      "deliverables": [
        "EmbeddingService class",
        "Batch processor",
        "Cache layer",
        "Unit tests (90% coverage)"
      ]
    },
    {
      "component_id": "SEMANTIC_002",
      "name": "Vector Database (Qdrant)",
      "type": "Database",
      "description": "Store and index embeddings for fast similarity search",
      "implementation": {
        "database": "Qdrant",
        "collection_name": "ideas_embeddings",
        "vector_size": 3072,
        "index_type": "HNSW",
        "quantization": "scalar"
      },
      "features": [
        "HNSW indexing for O(log n) search",
        "Payload filtering",
        "Batch operations",
        "Backup and replication",
        "Performance monitoring"
      ],
      "estimated_effort": 28,
      "deliverables": [
        "Qdrant deployment config",
        "Index management scripts",
        "Monitoring setup",
        "Backup procedures"
      ]
    },
    {
      "component_id": "SEMANTIC_003",
      "name": "Similarity Search Engine",
      "type": "Algorithm",
      "description": "Implement semantic search with ranking and filtering",
      "implementation": {
        "search_type": "cosine_similarity",
        "ranking": "BM25 + embedding_score",
        "top_k_results": 10,
        "filtering": "payload-based"
      },
      "features": [
        "Hybrid search (BM25 + semantic)",
        "Relevance ranking",
        "Result filtering and faceting",
        "Search query expansion",
        "Spell correction"
      ],
      "estimated_effort": 18,
      "deliverables": [
        "SearchEngine class",
        "Ranking algorithm",
        "Query parser",
        "Integration tests"
      ]
    },
    {
      "component_id": "SEMANTIC_004",
      "name": "Search API Endpoints",
      "type": "API",
      "description": "REST API for semantic search queries",
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/v1/search",
          "description": "Execute semantic search query",
          "request": {
            "query": "string",
            "filters": "object",
            "limit": "integer",
            "offset": "integer"
          },
          "response": {
            "results": "array[SearchResult]",
            "total_count": "integer",
            "execution_time_ms": "integer"
          }
        },
        {
          "method": "POST",
          "path": "/api/v1/search/similar",
          "description": "Find similar ideas to a given idea",
          "request": {"idea_id": "string", "limit": "integer"},
          "response": {"similar_ideas": "array[Idea]"}
        },
        {
          "method": "GET",
          "path": "/api/v1/search/stats",
          "description": "Get search statistics and metrics",
          "response": {
            "total_queries": "integer",
            "avg_latency_ms": "float",
            "top_queries": "array"
          }
        }
      ],
      "estimated_effort": 23,
      "deliverables": [
        "FastAPI route handlers",
        "Request validation",
        "Response serialization",
        "API documentation",
        "Integration tests"
      ]
    },
    {
      "component_id": "SEMANTIC_005",
      "name": "Search Caching Layer",
      "type": "Cache",
      "description": "Cache search results and embeddings for performance",
      "implementation": {
        "cache_backend": "Redis",
        "ttl_seconds": 3600,
        "cache_key_pattern": "search:{query_hash}:{filters_hash}"
